# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# ENTSO-E Transparency Platform — RESTful API security token.
# How to get one (see docs/sources/entsoe.md):
#   1. Register at https://transparency.entsoe.eu/
#   2. Email transparency@entsoe.eu, subject "Restful API access", with your
#      registered address in the body (~3 working days to approve).
#   3. Generate the token under My Account Settings.
# entsoe-py passes this as the `securityToken` query param for you.
ENTSOE_API_KEY=
